# ── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ── Database ────────────────────────────────────────────────────────────────
# Development (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./jarfin.db
#
# Production (Supabase PostgreSQL):
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── AI Provider: 'gemini', 'groq', or 'qwen' ───────────────────────────────
AI_PROVIDER=qwen

# AI / Gemini
GEMINI_API_KEY=

# AI / Groq (needed if AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-specdec

# AI / Qwen (needed if AI_PROVIDER=qwen)
DASHSCOPE_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-turbo
QWEN_CHAT_MODEL=qwen3.5-plus

# ── Google Cloud Vision (OCR) ───────────────────────────────────────────────
GOOGLE_CLOUD_CREDENTIALS=path/to/service-account.json

# ── Bot Mode: 'polling' for development, 'webhook' for production ──────────
BOT_MODE=webhook

# Webhook (only needed if BOT_MODE=webhook)
WEBHOOK_URL=https://your-domain.com
